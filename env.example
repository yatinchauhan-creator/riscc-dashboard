# Copy this file to .env and fill in values before deploying publicly.

# Port the backend listens on
PORT=3000

# Set this to a long random string BEFORE deploying publicly.
# Protects /api/settings and /api/sync (where API keys are managed)
# with a Bearer token. Leave unset for local-only/dev use.
# Example: openssl rand -hex 32
ADMIN_TOKEN=
